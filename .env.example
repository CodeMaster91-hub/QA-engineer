# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=qa_platform
DB_USERNAME=qa_user
DB_PASSWORD=your_db_password
DB_SCHEMA=public  # Tenant identifier (e.g., team1, team2)

# Redis (optional - set REDIS_ENABLED=false for in-memory mode)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3000
NODE_ENV=development

# Auth (set to false during development)
AUTH_ENABLED=false

# File Upload
MAX_FILE_SIZE=10485760

# JWT
JWT_SECRET=your_random_64_char_hex_string

# Authentik OIDC
AUTHENTIK_ISSUER=https://authentik.corp.example.com/application/o/qa-platform/
AUTHENTIK_AUTHORIZE_URL=https://authentik.corp.example.com/application/o/qa-platform/authorize/
AUTHENTIK_TOKEN_URL=https://authentik.corp.example.com/application/o/qa-platform/token/
AUTHENTIK_USERINFO_URL=https://authentik.corp.example.com/application/o/qa-platform/userinfo/
AUTHENTIK_CLIENT_ID=qa-platform
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_LOGOUT_URL=https://authentik.corp.example.com/application/o/qa-platform/end-session/
AUTHENTIK_ADMIN_GROUP=QA-Platform-Admins

# LLM Provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key
LLM_MOCK=false

# LLM Provider Info
LLM_PROVIDER_ID=openrouter
LLM_PROVIDER_NAME=OpenRouter

# LLM Model Aliases
LLM_DEFAULT_ALIAS=openrouter/owl-alpha
LLM_ALIAS_REQUIREMENTS=openrouter/owl-alpha
LLM_ALIAS_DRAFT=openrouter/owl-alpha
LLM_ALIAS_COVERAGE=openrouter/owl-alpha
LLM_ALIAS_REVIEW=openrouter/owl-alpha
LLM_ALIAS_DRY_RUN=openrouter/owl-alpha

# Pipeline
PIPELINE_CONCURRENCY=3
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2000

# TMS Provider
TMS_PROVIDER=testrail

# TestRail
TESTRAIL_URL=https://yourcompany.testrail.io
TESTRAIL_API_KEY=your-api-key
TESTRAIL_MOCK=true
TESTRAIL_PROJECT_ID=1
TESTRAIL_SUITE_ID=1
TESTRAIL_SECTION_ID=

# Zephyr Scale
ZEPHYR_URL=https://yourcompany.atlassian.net
ZEPHYR_API_TOKEN=your-token
ZEPHYR_MOCK=true

# Test IT
TESTIT_URL=https://yourcompany.testit.software
TESTIT_API_TOKEN=your-token
TESTIT_MOCK=true

# TestLink
TESTLINK_URL=https://yourcompany.testlink.org
TESTLINK_API_KEY=your-api-key
TESTLINK_MOCK=true
